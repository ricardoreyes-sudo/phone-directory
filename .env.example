# Supabase — Transaction pooler (puerto 6543), usado en runtime/Vercel
DATABASE_URL="postgresql://postgres.xxxx:[password]@aws-0-us-east-1.pooler.supabase.com:6543/postgres"

# Supabase — Conexión directa (puerto 5432), usada solo para migraciones
DIRECT_URL="postgresql://postgres:[password]@db.xxxx.supabase.co:5432/postgres"

# CloudTalk
CLOUDTALK_API_KEY_ID="your_api_key_id_here"
CLOUDTALK_API_KEY_SECRET="your_api_key_secret_here"
CLOUDTALK_CALLER_EXTENSION="100"
